/* ── Gemini — used for structured JSON (soil, crops, market, plant scan) ── */
async function gemini(prompt, imgB64 = null) {
  const parts = imgB64
    ? [{ inline_data: { mime_type: "image/jpeg", data: imgB64 } }, { text: prompt }]
    : [{ text: prompt }];
  try {
    const r = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${KEYS.gemini}`,
      { method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ contents:[{ parts }] }) }
    );
    const d = await r.json();
    return (d?.candidates?.[0]?.content?.parts?.[0]?.text||"").replace(/```json|```/g,"").trim();
  } catch { return ""; }
}

/* ── Groq — routed via Anthropic API proxy to bypass CORS ── */
async function groqChat(messages) {
  // Groq direct calls are blocked by CORS in browser sandboxes.
  // We use the Anthropic /v1/messages proxy which IS accessible from artifacts.
  try {
    const systemMsg = messages.find(m => m.role === "system");
    const convoMsgs = messages.filter(m => m.role !== "system");

    const r = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 200,
        system: systemMsg?.content || "You are a helpful farming assistant.",
        messages: convoMsgs.map(m => ({
          role: m.role === "assistant" ? "assistant" : "user",
          content: m.content,
        })),
      }),
    });
    if (!r.ok) {
      const err = await r.json().catch(() => ({}));
      console.error("Chat API error:", r.status, err);
      return "";
    }
    const d = await r.json();
    return d?.content?.[0]?.text?.trim() || "";
  } catch (e) {
    console.error("Chat fetch error:", e);
    return "";
  }
}

const pj = (s, fb) => { try { return JSON.parse(s); } catch { return fb; } };

